# ---- Database ----
# Local dev (default, zero setup): SQLite
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Production (Postgres) -- uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ---- Redis (notification queue + rate limiting) ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth ----
# CHANGE THIS in production to a long random string
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Feature tuning (safe defaults; override only if needed) ----
RECENTLY_VIEWED_MAX_ITEMS=20
BROWSING_HISTORY_MAX_ITEMS=50
BROWSING_HISTORY_TTL_DAYS=30
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RATE_LIMIT_PER_USER_PER_HOUR=10
MAX_PAGE_SIZE=100

ENV=development
